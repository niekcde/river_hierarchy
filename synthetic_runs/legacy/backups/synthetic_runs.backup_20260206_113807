def stratified_sample_ids(
    summary_df: pd.DataFrame,
    n_total: int,
    k_bins: int = 4,
    ebi_bins: int = 4,
    seed: int = 123,
) -> list:
    if n_total <= 0:
        return []
    df = summary_df.copy()
    df = df.dropna(subset=["k_mean", "ebi_mean", "network_id"])
    if df.empty:
        return []
    # quantile binning with duplicate handling
    df["k_bin"] = pd.qcut(df["k_mean"], q=k_bins, duplicates="drop")
    df["ebi_bin"] = pd.qcut(df["ebi_mean"], q=ebi_bins, duplicates="drop")
    # combine bins
    df["bin"] = df["k_bin"].astype(str) + "|" + df["ebi_bin"].astype(str)
    rng = np.random.default_rng(seed)
    # target per bin
    bins = df["bin"].unique().tolist()
    if not bins:
        return []
    per_bin = max(1, n_total // len(bins))
    sampled_ids = []
    for b in bins:
        group = df[df["bin"] == b]
        take = min(per_bin, len(group))
        if take == 0:
            continue
        sampled = group.sample(n=take, random_state=seed)
        sampled_ids.extend(sampled["network_id"].astype(int).tolist())
    # fill remainder from remaining pool
    remaining = n_total - len(sampled_ids)
    if remaining > 0:
        remaining_pool = df[~df["network_id"].isin(sampled_ids)]
        if not remaining_pool.empty:
            extra = remaining_pool.sample(n=min(remaining, len(remaining_pool)), random_state=seed)
            sampled_ids.extend(extra["network_id"].astype(int).tolist())
    return sampled_ids[:n_total]


def run_sampled_realizations(
    sampled_dir: str | Path,
    out_dir: str | Path,
    n_benchmarks: int,
    n_random_per_benchmark: int,
    seed: int = 123,
    k_bins: int = 4,
    ebi_bins: int = 4,
    use_admissible: bool = True,
    output_mode: str = "parquet_outlet",
    keep_intermediate: bool = False,
    write_netcdf: bool = False,
    x=0.1,
):
    """
    Sample admissible networks from summary, load recipes by network_id,
    run RAPID, and store outputs efficiently.
    """
    sampled_dir = Path(sampled_dir)
    out_dir = Path(out_dir)
    out_dir.mkdir(parents=True, exist_ok=True)
    print('print sampled dir:', sampled_dir, '\n\n')
    summary = _load_summary_table(sampled_dir)
    summary["admissible"] = summary["k_ratio"] <= ((1 - x) / x)
    # print(summary.shape[0])
    if use_admissible and "admissible" in summary.columns:
        summary = summary[summary["admissible"] == True]
    if "is_benchmark" not in summary.columns or "geometry_id" not in summary.columns:
        raise ValueError("summary must include is_benchmark and geometry_id columns")
    # print(summary.shape[0], sampled_dir)
    benches = summary[summary["is_benchmark"] == True]
    # print(benches.shape[0])
    bench_ids = stratified_sample_ids(benches, n_benchmarks, k_bins, ebi_bins, seed)
    if not bench_ids:
        raise ValueError("No benchmark network_ids selected; check summary filters/binning.")
    network_ids = []
    sample_types = {}
    geom_for = summary.set_index("network_id")["geometry_id"].to_dict()
    for bid in bench_ids:
        network_ids.append(int(bid))
        sample_types[int(bid)] = "benchmark"
        gid = geom_for.get(int(bid))
        if gid is None:
            continue
        candidates = summary[(summary["geometry_id"] == gid) & (summary["is_benchmark"] == False)]
        candidates = candidates[~candidates["network_id"].isin(network_ids)]
        if candidates.empty:
            continue
        take = min(n_random_per_benchmark, len(candidates))
        picks = candidates.sample(n=take, random_state=seed)["network_id"].astype(int).tolist()
        for pid in picks:
            network_ids.append(int(pid))
            sample_types[int(pid)] = "random_from_benchmark"
    # print(len(bench_ids), len(candidates))
    if not network_ids:
        raise ValueError("No network_ids selected after benchmark/random expansion.")
    recipes_path = _pick_recipes_path(sampled_dir)
    parquet_writer = None
    if output_mode == "parquet_outlet":
        schema = pa.schema([
            ("network_id", pa.int64()),
            ("geometry_id", pa.int64()),
            ("sample_type", pa.string()),
            ("time", pa.int64()),
            ("Q", pa.float64()),
        ])
        parquet_path = out_dir / "q_outlet.parquet"
        parquet_writer = pq.ParquetWriter(parquet_path, schema)
    results = []
    for network_id in tqdm(network_ids, total=len(network_ids), desc="Running networks"):
        net = load_network_by_id(recipes_path, int(network_id))
        G = rivernetwork_to_rapid_graph(net)
        work_dir = out_dir / f"network_{int(network_id):06d}"
        work_dir.mkdir(parents=True, exist_ok=True)
        create_conn_file(G, directory=str(work_dir) + "/")
        riv_order = create_riv_file(G, directory=str(work_dir) + "/")
        compute_reach_ratios(G, use_widths=True, directory=str(work_dir) + "/")
        compute_area_csv(G, directory=str(work_dir) + "/")
        X = 0.1
        create_routing_parameters(G, directory=str(work_dir) + "/", xfc_value=X)
        dt = compute_dt_from_K(str(work_dir) + "/", X, True)
        steps, step_duration = build_first_part(dt)
        runOffC = steps + [0] * 2000
        times = create_runoff(G, directory=str(work_dir) + "/", dt_seconds=dt, runOffC=runOffC, return_times=True)
        outlet_reach_id = _find_outlet_reach_id(G)
        outlet_idx = None
        if outlet_reach_id is not None and outlet_reach_id in riv_order:
            outlet_idx = riv_order.index(outlet_reach_id)
        out_path = work_dir / f"Qout_{int(network_id):06d}.nc"
        if out_path.exists():
            out_path.unlink()
        if not os.access(work_dir, os.W_OK):
            raise PermissionError(f"Output directory not writable: {work_dir}")
        qout_path, qout = run_rapid(
            str(work_dir),
            ROUTING_TIMESTEP_SECONDS=dt,
            runType="sampled",
            seed=int(network_id),
            output_path=str(out_path),
            return_qout=True,
        )
        if output_mode == "parquet_outlet":
            if outlet_idx is None:
                raise ValueError(f"Outlet reach not found for network_id={network_id}")
            q = qout[:, outlet_idx].astype(float)
            table = pa.table({
                "network_id": pa.array([int(network_id)] * len(times)),
                "geometry_id": pa.array([int(geom_for.get(int(network_id), -1))] * len(times)),
                "sample_type": pa.array([sample_types.get(int(network_id), "unknown")] * len(times)),
                "time": pa.array(times),
                "Q": pa.array(q),
            })
            parquet_writer.write_table(table)
        results.append({
            "network_id": int(network_id),
            "dt": float(dt),
            "qout_path": str(qout_path),
        })
        if not write_netcdf and out_path.exists():
            out_path.unlink()
        if not keep_intermediate:
            if write_netcdf and out_path.exists():
                shutil.move(str(out_path), str(out_dir / out_path.name))
            shutil.rmtree(work_dir)
    if parquet_writer is not None:
        parquet_writer.close()
    return results


def resample(curve, N):
    x_old = np.linspace(0,1,len(curve))
    x_new = np.linspace(0,1,N)
    return np.interp(x_new, x_old, curve)
