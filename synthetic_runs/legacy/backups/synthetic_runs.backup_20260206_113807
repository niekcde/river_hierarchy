def build_first_part(dt):
    """
    Returns a dt-invariant runoff curve.
    Output:
        runOffC - runoff intensity values sampled at routing dt
        durations - list of segment durations in seconds
    """

    # ------------------------------------------------------------
    # 1. Fixed physical durations (seconds)
    # ------------------------------------------------------------
    T_A = 24*10*60*60   # 10 days
    T_B = 24*10*60*60
    T_C = 24*10*60*60
    T_D = 24*10*60*60
    T_E = 24*1*60*60
    durations = [T_A, T_B, T_C, T_D, T_E]
    T_total = sum(durations)
    # ------------------------------------------------------------
    # 2. Build a *continuous* normalized time axis
    #    (independent of dt)
    # ------------------------------------------------------------
    N_base = 3000   # high resolution to make curve smooth
    t_base = np.linspace(0, T_total, N_base)
    # helper to define each phase in continuous time
    def segment_mask(t, t0, t1):
        return (t >= t0) & (t < t1)
    # ------------------------------------------------------------
    # 3. Create continuous runoff intensity r(t)
    # ------------------------------------------------------------
    r = np.zeros_like(t_base)
    # A: 0
    t0 = 0
    t1 = T_A
    # r already 0
    # B: ramp 0 → 1
    t2      = t1 + T_B
    mask    = segment_mask(t_base, t1, t2)
    r[mask] = np.linspace(0, 1, mask.sum())
    # C: plateau 1
    t3      = t2 + T_C
    mask    = segment_mask(t_base, t2, t3)
    r[mask] = 1.0
    # D: ramp 1 → 50
    t4 = t3 + T_D
    mask = segment_mask(t_base, t3, t4)
    r[mask] = np.linspace(1, 10, mask.sum())
    # E: ramp 50 → 0
    t5 = t4 + T_E
    mask = segment_mask(t_base, t4, t5)
    r[mask] = np.linspace(10, 0, mask.sum())
    # ------------------------------------------------------------
    # 4. Sample r(t) at the routing dt
    # ------------------------------------------------------------
    t       = np.arange(0, T_total, dt)
    runOffC = np.interp(t, t_base, r)
    return runOffC.tolist(), durations
